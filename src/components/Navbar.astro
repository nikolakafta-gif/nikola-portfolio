---
import ButtonExpand from "./ButtonExpand.astro";

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const prefix = isHome ? "" : "/";

const navLinks = [
  { label: "Home", href: `${prefix}#home` },
  { label: "About me", href: `${prefix}#about` },
  { label: "Work", href: `${prefix}#work` },
  { label: "Testimonial", href: `${prefix}#testimonials` },
  { label: "FAQ", href: `${prefix}#faq` },
  { label: "Certificates", href: `${prefix}#certificates` },
];
---

<header class="navbar" id="home">
  <nav class="navbar__inner">
    <ul class="navbar__links">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="navbar__link">{link.label}</a>
        </li>
      ))}
    </ul>
    <div class="navbar__actions">
      <button class="navbar__menu-toggle" aria-label="Open menu">
        <img src="/assets/images/icon-menu.svg" alt="" width="24" height="24" />
      </button>
      {isHome && <ButtonExpand href="/contact" label="Let's Collaborate" variant="dark" />}
    </div>
  </nav>

  <div class="navbar__overlay" aria-hidden="true"></div>
  <div class="navbar__mobile-menu" aria-hidden="true">
    <div class="navbar__mobile-inner">
      <div class="navbar__mobile-header">
        <p class="navbar__mobile-title">Menu</p>
        <button class="navbar__menu-close" aria-label="Close menu">
          <img src="/assets/images/icon-close.svg" alt="" width="16" height="16" />
        </button>
      </div>
      <div class="navbar__mobile-links">
        {navLinks.map((link) => (
          <a href={link.href} class="navbar__mobile-link">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.navbar__menu-toggle');
  const close = document.querySelector('.navbar__menu-close');
  const overlay = document.querySelector('.navbar__overlay');
  const menu = document.querySelector('.navbar__mobile-menu');
  const mobileLinks = document.querySelectorAll('.navbar__mobile-link');

  function openMenu() {
    menu?.classList.add('is-open');
    overlay?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    overlay?.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
  mobileLinks.forEach(link => link.addEventListener('click', closeMenu));
</script>


<style>
  @keyframes nav-slide-right {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes nav-slide-left {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: none; }
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 6em;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9375em 1.25em;
  }

  .navbar__inner {
    max-width: 1520px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5625em 0.9375em;
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .navbar__links {
    display: inline-flex;
    align-items: center;
    gap: 0.375em;
    background-color: var(--color-primary-05);
    border: 1px solid var(--color-primary-05);
    border-radius: var(--radius-pill);
    padding: 0.25em 0.625em;
    animation: nav-slide-right 1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .navbar__links li {
    display: inline-flex;
  }

  .navbar__link {
    color: var(--color-primary-60);
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0.25px;
    padding: 0.5em 0.6875em;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .navbar__link:hover {
    color: var(--color-primary);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 1em;
    animation: nav-slide-left 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .navbar__menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5em;
  }

  .navbar__overlay {
    display: none;
  }

  .navbar__mobile-menu {
    display: none;
  }

  @media (max-width: 991px) {
    .navbar__links {
      display: none;
    }

    .navbar__menu-toggle {
      display: flex;
    }

    .navbar__actions :global(.btn-expand) {
      display: none;
    }

    .navbar__overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background-color: rgba(0, 0, 0, 0.5);
      z-index: 40;
    }

    .navbar__overlay.is-open {
      display: block;
    }

    .navbar__mobile-menu {
      display: flex;
      position: fixed;
      top: 0;
      right: 0;
      width: 100%;
      max-width: 300px;
      height: 100vh;
      z-index: 99;
      transform: translateX(100%);
      transition: transform var(--transition-smooth);
    }

    .navbar__mobile-menu.is-open {
      transform: translateX(0);
    }

    .navbar__mobile-inner {
      background-color: var(--color-white);
      width: 100%;
      max-width: 300px;
      height: 100vh;
      position: fixed;
      top: 0;
      right: 0;
    }

    .navbar__mobile-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      width: 100%;
      padding: 0 1em;
      margin-top: 0.625em;
      margin-bottom: 0.625em;
    }

    .navbar__mobile-title {
      font-family: var(--font-body);
      font-size: 1em;
      font-weight: 600;
      color: var(--color-primary);
      margin-bottom: 0;
    }

    .navbar__menu-close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25em;
    }

    .navbar__mobile-links {
      display: flex;
      flex-direction: column;
      gap: 1em;
      width: 100%;
      padding: 0 1em;
    }

    .navbar__mobile-link {
      font-family: var(--font-body);
      font-size: 1em;
      color: var(--color-primary);
      text-decoration: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar__links,
    .navbar__actions {
      animation: none;
    }
  }
</style>
