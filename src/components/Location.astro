---
import { GlobeBars } from "./ui/cobe-globe-bars"
---

<section class="location">
  <div class="location__inner container">
    <div class="location__content">
      <div class="location__text">
        <p class="location__label" data-fade-up>Based in</p>
        <h2 class="location__heading" data-fade-up>Niš, <span class="location__italic">Serbia</span></h2>
        <p class="location__desc" data-fade-up>Available for remote work worldwide. Let's connect regardless of timezone.</p>
        <div class="location__timezone" data-fade-up>
          <span class="location__tz-dot"></span>
          <span class="location__tz-label">CET</span>
          <span class="location__tz-sep">·</span>
          <time class="location__tz-time" id="location-clock">--:--:--</time>
        </div>
      </div>
      <div class="location__globe">
        <GlobeBars client:load targetPhi={1.35} targetTheta={0.25} />
      </div>
    </div>
  </div>
</section>

<script>
  function updateClock() {
    const el = document.getElementById("location-clock");
    if (!el) return;
    const now = new Date();
    const time = now.toLocaleTimeString("en-GB", {
      timeZone: "Europe/Belgrade",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });
    el.textContent = time;
  }

  updateClock();
  setInterval(updateClock, 1000);
</script>

<style>
  .location {
    padding-top: 10em;
    padding-bottom: 0;
  }

  .location__inner {
    max-width: 1272px;
  }

  .location__content {
    display: flex;
    align-items: center;
    gap: 4em;
  }

  .location__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .location__label {
    color: var(--color-accent);
    font-size: 0.875em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
  }

  .location__heading {
    font-family: var(--font-body);
    color: var(--color-primary);
    font-size: 4em;
    font-weight: 500;
    line-height: 1.1;
    margin: 0;
  }

  .location__italic {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -1px;
  }

  .location__desc {
    color: var(--color-primary-60);
    font-size: 1.125em;
    line-height: 1.4;
    margin: 0;
    max-width: 28em;
  }

  /* Timezone */
  .location__timezone {
    display: flex;
    align-items: center;
    gap: 0.5em;
    background: var(--color-primary-05, rgba(27, 29, 30, 0.05));
    border: 1px solid var(--color-primary-10);
    border-radius: var(--radius-pill);
    padding: 0.5em 1em;
    width: fit-content;
  }

  .location__tz-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background-color: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.5);
    flex-shrink: 0;
  }

  .location__tz-label {
    font-size: 0.875em;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .location__tz-sep {
    color: var(--color-primary-30);
    font-size: 0.875em;
    line-height: 1;
  }

  .location__tz-time {
    font-size: 0.875em;
    font-weight: 500;
    color: var(--color-primary-60);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.5px;
  }

  .location__globe {
    flex: 1;
    min-width: 20em;
    max-width: 28em;
  }

  @media (max-width: 991px) {
    .location {
      padding-top: 2.5em;
    }

    .location__content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 2em;
    }

    .location__text {
      align-items: center;
    }

    .location__heading {
      font-size: 3em;
    }

    .location__timezone {
      align-self: center;
    }

    .location__globe {
      flex: none;
      width: 100%;
      max-width: 20em;
      align-self: center;
    }

    .location__desc {
      max-width: 100%;
    }
  }

  @media (max-width: 767px) {
    .location {
      padding-top: 3.75em;
    }

    .location__heading {
      font-size: 2.5em;
    }

    .location__globe {
      max-width: 16em;
    }
  }

  @media (max-width: 479px) {
    .location__globe {
      max-width: 14em;
    }
  }
</style>
